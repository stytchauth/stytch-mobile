#!/bin/sh
set -e

SDK=$1
PLATFORM=$2

ROOT_DIR=`pwd`
IOS_DIR=$ROOT_DIR/ios
SRC_DIR=$ROOT_DIR/source
SDK_WORKING_DIR=$SRC_DIR/sdks
SHARED_WORKING_DIR=$SRC_DIR/shared

usage() {
    echo "Usage: ./build [sdk] [platform]"
    echo "  sdk:      consumer | b2b | shared | (omit for both)"
    echo "  platform: android | ios | rn | (omit for all)"
    echo ""
    echo "Examples:"
    echo "  ./build                  # build everything"
    echo "  ./build shared           # shared SDK only"
    echo "  ./build consumer         # consumer SDK, all platforms"
    echo "  ./build b2b              # B2B SDK, all platforms"
    echo "  ./build consumer ios     # consumer iOS only"
    echo "  ./build b2b android      # B2B android only"
}

buildAndPublishSwiftUtils() {
    cd $ROOT_DIR/source/StytchSwiftUtils
    # clear out any old stuff
    rm -rf derived archives StytchSwiftUtils.xcframework StytchSwiftUtils-Swift.h

    # build (to get the header file)
    xcodebuild -project StytchSwiftUtils.xcodeproj -scheme StytchSwiftUtils -configuration Release -destination 'generic/platform=iOS' -derivedDataPath ./derived IPHONEOS_DEPLOYMENT_TARGET=15.0 SKIP_INSTALL=NO BUILD_LIBRARIES_FOR_DISTRIBUTION=YES ONLY_ACTIVE_ARCH=NO build
    xcodebuild -project StytchSwiftUtils.xcodeproj -scheme StytchSwiftUtils -configuration Release -destination 'generic/platform=iOS Simulator' -derivedDataPath ./derived IPHONEOS_DEPLOYMENT_TARGET=15.0 SKIP_INSTALL=NO BUILD_LIBRARIES_FOR_DISTRIBUTION=YES ONLY_ACTIVE_ARCH=NO build

    # archive project
    xcodebuild -project StytchSwiftUtils.xcodeproj -scheme StytchSwiftUtils -configuration Release -archivePath "./archives/iOS" -destination 'generic/platform=iOS' -derivedDataPath ./derived IPHONEOS_DEPLOYMENT_TARGET=15.0 SKIP_INSTALL=NO BUILD_LIBRARIES_FOR_DISTRIBUTION=YES ONLY_ACTIVE_ARCH=NO archive
    xcodebuild -project StytchSwiftUtils.xcodeproj -scheme StytchSwiftUtils -configuration Release -archivePath "./archives/Simulator" -destination 'generic/platform=iOS Simulator' -derivedDataPath ./derived IPHONEOS_DEPLOYMENT_TARGET=15.0 SKIP_INSTALL=NO BUILD_LIBRARIES_FOR_DISTRIBUTION=YES ONLY_ACTIVE_ARCH=NO archive

    # create xcframework
    xcodebuild -create-xcframework \
        -framework archives/iOS.xcarchive/Products/Library/Frameworks/StytchSwiftUtils.framework \
        -framework archives/Simulator.xcarchive/Products/Library/Frameworks/StytchSwiftUtils.framework \
        -output StytchSwiftUtils.xcframework

    # copy header file to usable location (for cinterop generation)
    cp ./derived/Build/Intermediates.noindex/StytchSwiftUtils.build/Release-iphoneos/StytchSwiftUtils.build/DerivedSources/StytchSwiftUtils-Swift.h $SHARED_WORKING_DIR/sdk/shared/src/iosMain/interop/StytchSwiftUtils-device.h
    cp ./derived/Build/Intermediates.noindex/StytchSwiftUtils.build/Release-iphonesimulator/StytchSwiftUtils.build/DerivedSources/StytchSwiftUtils-Swift.h $SHARED_WORKING_DIR/sdk/shared/src/iosMain/interop/StytchSwiftUtils-simulator.h

    # copy xcframework to usable locations
    cp -r ./StytchSwiftUtils.xcframework $SHARED_WORKING_DIR/sdk/shared/src/iosMain/interop/
    cp -r ./StytchSwiftUtils.xcframework $IOS_DIR
}

buildAndPublishSharedSdkFirst() {
    echo "Building shared stuff first..."
    buildAndPublishSwiftUtils

    cd $SHARED_WORKING_DIR
    ./gradlew :sdk:shared:assembleStytchSharedSDKXCFramework :sdk:shared:publishToMavenLocal
    cp -r sdk/shared/build/XCFrameworks/release/StytchSharedSDK.xcframework $IOS_DIR
}

# --- Consumer builds ---

buildConsumerAndroid() {
    cd $SDK_WORKING_DIR
    echo "Building consumer android artifact..."
    ./gradlew :sdk:consumer-headless:publishToMavenLocal
}

buildConsumerIos() {
    echo "Building consumer iOS artifacts..."
    cd $SDK_WORKING_DIR
    ./gradlew assembleStytchConsumerSDKXCFramework
    cp -r sdk/consumer-headless/build/XCFrameworks/release/StytchConsumerSDK.xcframework $IOS_DIR
}

buildConsumerRn() {
    cd $SDK_WORKING_DIR
    echo "Building consumer RN artifacts..."
    ./gradlew kotlinUpgradeYarnLock :sdk:consumer-headless:assemble :sdk:consumer-headless:publishToMavenLocal :sdk:consumer-headless:jsBrowserProductionLibraryDistribution
    mkdir -p $SRC_DIR/react-native/consumer/lib
    cp -r sdk/consumer-headless/build/dist/js/productionLibrary/consumer-headless* $SRC_DIR/react-native/consumer/lib
    cd $SRC_DIR/react-native/consumer
    yarn build
    updateConsumerRnDemoApp
}

updateConsumerRnDemoApp() {
    cd $ROOT_DIR/examples/rn
    yarn remove @stytch/react-native-consumer
    yarn add file:$SRC_DIR/react-native/consumer
}

# --- B2B builds ---

buildB2BAndroid() {
    cd $SDK_WORKING_DIR
    echo "Building B2B android artifact..."
    ./gradlew :sdk:b2b-headless:publishToMavenLocal
}

buildB2BIos() {
    echo "Building B2B iOS artifacts..."
    cd $SDK_WORKING_DIR
    ./gradlew assembleStytchB2BSDKXCFramework
    cp -r sdk/b2b-headless/build/XCFrameworks/release/StytchB2BSDK.xcframework $IOS_DIR
}

buildB2BRn() {
    cd $SDK_WORKING_DIR
    echo "Building B2B RN artifacts..."
    ./gradlew kotlinUpgradeYarnLock :sdk:b2b-headless:assemble :sdk:b2b-headless:publishToMavenLocal :sdk:b2b-headless:jsBrowserProductionLibraryDistribution
    mkdir -p $SRC_DIR/react-native/b2b/lib
    cp -r sdk/b2b-headless/build/dist/js/productionLibrary/b2b-headless* $SRC_DIR/react-native/b2b/lib
    cd $SRC_DIR/react-native/b2b
    yarn build
}

# --- Dispatch ---

buildConsumer() {
    if [ -z "$PLATFORM" ]; then
        buildConsumerAndroid
        buildConsumerIos
        buildConsumerRn
    elif [ "$PLATFORM" = "android" ]; then
        buildConsumerAndroid
    elif [ "$PLATFORM" = "ios" ]; then
        buildConsumerIos
    elif [ "$PLATFORM" = "rn" ]; then
        buildConsumerRn
    fi
}

buildB2B() {
    if [ -z "$PLATFORM" ]; then
        buildB2BAndroid
        buildB2BIos
        buildB2BRn
    elif [ "$PLATFORM" = "android" ]; then
        buildB2BAndroid
    elif [ "$PLATFORM" = "ios" ]; then
        buildB2BIos
    elif [ "$PLATFORM" = "rn" ]; then
        buildB2BRn
    fi
}

main() {
    if [ "$SDK" = "shared" ]; then
        buildAndPublishSharedSdkFirst
        cd $ROOT_DIR
        echo "Done."
        return
    fi

    if [ -n "$SDK" ] && [ "$SDK" != "consumer" ] && [ "$SDK" != "b2b" ]; then
        echo "Error: unknown sdk '$SDK'."
        usage
        exit 1
    fi

    if [ -n "$PLATFORM" ] && [ "$PLATFORM" != "android" ] && [ "$PLATFORM" != "ios" ] && [ "$PLATFORM" != "rn" ]; then
        echo "Error: unknown platform '$PLATFORM'."
        usage
        exit 1
    fi

    buildAndPublishSharedSdkFirst

    if [ -z "$SDK" ]; then
        echo "Building consumer and B2B SDKs..."
        buildConsumer
        buildB2B
    elif [ "$SDK" = "consumer" ]; then
        echo "Building consumer SDK..."
        buildConsumer
    elif [ "$SDK" = "b2b" ]; then
        echo "Building B2B SDK..."
        buildB2B
    fi

    cd $ROOT_DIR
    echo "Done."
}

main
