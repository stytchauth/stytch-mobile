{
  "name": "@stytch/react-native-b2b",
  "version": "0.0.1",
  "type": "module",
  "description": "Stytch's official React Native Library",
  "summary": "Stytch's official React Native Library",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "lib",
    "android",
    "ios",
    "src/NativeStytchBridge.ts",
    "*.podspec",
    "package.json",
    "src/app.plugin.cjs"
  ],
  "license": "MIT",
  "homepage": "https://stytch.com/docs/sdks/react-native-sdk",
  "author": {
    "name": "Stytch",
    "url": "https://github.com/stytchauth"
  },
  "scripts": {
    "setup": "cp -r ../shared/. .",
    "test": "yarn setup && jest",
    "build": "yarn setup && rm -rf dist && tsc && babel src -d dist --copy-files --extensions '.ts,.tsx'",
    "lint": "yarn setup && eslint src/ && prettier . --check",
    "format": "yarn setup && eslint src/ --fix && prettier . --write"
  },
  "dependencies": {
    "@js-joda/core": "3.2.0",
    "react-native-get-random-values": "^2.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.27.5",
    "@babel/core": "^7.27.4",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.39.2",
    "@expo/config-plugins": "^54.0.4",
    "@react-native/babel-preset": "0.81.1",
    "@react-native/codegen": "0.81.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.8",
    "babel-jest": "^30.3.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-test-renderer": "19.1.0",
    "tsc": "^2.0.4",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.57.0"
  },
  "peerDependencies": {
    "react": ">= 17.0.2",
    "react-native": ">= 0.80.x"
  },
  "codegenConfig": {
    "name": "StytchBridge",
    "type": "modules",
    "jsSrcsDir": "./src",
    "android": {
      "javaPackageName": "com.stytch.mobile.bridge"
    }
  }
}
